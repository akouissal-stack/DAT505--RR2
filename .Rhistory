# Extract 95% confidence intervals for each topic and outlet
for (t in 1:15) {
cat("\nTopic", t, "-", topic_labels[t], "\n")
print(apply(boot_results[[t]], 2, quantile, probs = c(0.025, 0.975)))
}
library(ggplot2)
# Build a dataframe of bootstrapped CIs
plot_data <- data.frame()
for (t in 1:15) {
ci <- apply(boot_results[[t]], 2, quantile, probs = c(0.025, 0.5, 0.975))
for (src in c("sourceHespress", "sourceHibapress", "sourceLe360")) {
plot_data <- rbind(plot_data, data.frame(
topic  = topic_labels[t],
source = gsub("source", "", src),
lo     = ci[1, src],
mid    = ci[2, src],
hi     = ci[3, src]
))
}
}
# Plot
ggplot(plot_data, aes(x = mid, y = topic, color = source)) +
geom_point(position = position_dodge(0.5), size = 2) +
geom_errorbarh(aes(xmin = lo, xmax = hi),
position = position_dodge(0.5), height = 0.3) +
geom_vline(xintercept = 0, linetype = "dashed", color = "gray40") +
facet_wrap(~ source) +
labs(
title = "Effect of News Outlet on Cultural Topic Prevalence",
subtitle = "Bootstrapped 95% Confidence Intervals (ref: Akhbarona)",
x = "Coefficient (difference in topic proportion vs Akhbarona)",
y = NULL
) +
theme_minimal() +
theme(legend.position = "none")
# ANOVA for each topic
for (t in 1:15) {
cat("\nTopic", t, "-", topic_labels[t], "\n")
aov_fit <- aov(stm_model$theta[, t] ~ source, data = meta_aligned)
print(summary(aov_fit))
}
# ============================================================
# ANOVA + TUKEY HSD FOR EACH TOPIC
# ============================================================
for (t in 1:15) {
cat("\n============\n")
cat("Topic", t, "-", topic_labels[t], "\n")
cat("============\n")
# ANOVA
aov_fit <- aov(stm_model$theta[, t] ~ source, data = meta_aligned)
cat("\nANOVA:\n")
print(summary(aov_fit))
# Tukey HSD
cat("\nTukey HSD:\n")
print(TukeyHSD(aov_fit))
}
library(tidyverse)
student = read_delim("student-mat.csv", delim = ";")
View(student)
model <- lm(G3 ~ studytime + absences + failures +
schoolsup + famsup + paid + Medu + Fedu + higher,
data = student)
summary(model)
#On using the predict() function. Predict allows you to use a model on new data.
#To do so, the workflow is the following:
#1) You use or create a dataset with "new" data. Of course, you need to make sure that this data contains all the information used in the model. For instance, if my model contains study time, failures, absences, internet access, and health condition, I should generate data like this:
fictional_student <- data.frame(
studytime = 3,        # studies 5-10 hours a week
absences = 4,         # fairly present
failures = 0,         # never failed a class
schoolsup = "no",     # no extra school support
famsup = "yes",       # family helps at home
paid = "no",          # no paid tutoring
Medu = 3,             # mom has secondary education
Fedu = 2,             # dad has some schooling
higher = "yes"        # wants to go to university
)
#NB: here I only ask you for one new data point (i.e. one student), but you could build a dataset of multiple new students.
#2) Use the model on this new data, using the following syntax. It's good to add the interval = "confidence", level = 0.95 arguments to get the 95% confidence interval and have an idea of the margin of precision of your prediction
prediction <- predict(model, newdata = fictional_student,
interval = "confidence", level = 0.95)
prediction
install.packages("caret")
library(caret)
postResample(pred = predict(model), obs = student$G3)
# freeze randomness so we get the same split every time
set.seed(123)
# total number of students = 395
# 20% goes to test (79 students), 80% goes to train (316 students)
n <- nrow(student)
ntest <- round(0.2 * n)
ntrain <- n - ntest
# randomly pick 316 row numbers for the training set
train_rows <- sample(1:n, ntrain)
# training set = the 316 selected students
# test set = the remaining 79 students (minus sign = everyone NOT selected)
student_train <- student[train_rows, ]
student_test <- student[-train_rows, ]
# train the model on the 316 training students only
# the 79 test students are completely hidden from it
model_train <- lm(G3 ~ studytime + absences + failures +
schoolsup + famsup + paid + Medu + Fedu + higher,
data = student_train)
# predict G3 for the 79 test students the model never saw
# then compare predictions to their actual grades
postResample(pred = predict(model_train, student_test), obs = student_test$G3)
library(caret)
# tell caret we want LOOCV
tc <- trainControl(method = "LOOCV")
# train the model using LOOCV
model_loocv <- train(G3 ~ studytime + absences + failures +
schoolsup + famsup + paid + Medu + Fedu + higher,
data = student,
method = "lm",
trControl = tc)
# see the results
model_loocv$results
# tell caret we want 10-fold cross validation
tc <- trainControl(method = "cv", number = 10)
# train the model using 10-fold CV
model_kfold <- train(G3 ~ studytime + absences + failures +
schoolsup + famsup + paid + Medu + Fedu + higher,
data = student,
method = "lm",
trControl = tc)
# see the results
model_kfold$results
# tell caret we want bootstrap with 1000 samples
tc <- trainControl(method = "boot", number = 1000)
# train the model using bootstrap
model_boot <- train(G3 ~ studytime + absences + failures +
schoolsup + famsup + paid + Medu + Fedu + higher,
data = student,
method = "lm",
trControl = tc)
# see the results
model_boot$results
library(caret)
# LOOCV for both evaluation and finding best lambda
tc <- trainControl(method = "LOOCV")
# lasso regression using all behavioral and demographic variables
model_lasso <- train(G3 ~ studytime + absences + failures + schoolsup +
famsup + paid + Medu + Fedu + higher + age +
address + famsize + Pstatus + Mjob + Fjob +
reason + guardian + traveltime + activities +
nursery + internet + romantic + famrel +
freetime + goout + Dalc + Walc + health + sex,
data = student,
method = "glmnet",
tuneGrid = expand.grid(alpha = 1,        # 1 = lasso
lambda = seq(0, 10, 0.1)),
metric = "RMSE",
trControl = tc)
# best model results
model_lasso$results[which(model_lasso$results$lambda == model_lasso$finalModel$lambdaOpt),]
# which variables survived (non zero coefficients)
coef(model_lasso$finalModel, model_lasso$finalModel$lambdaOpt)
# Quick check
glimpse(data)
source("~/.active-rstudio-document")
View(tc)

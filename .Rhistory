install.packages("fixest", type = "binary")
##PART 3
library(fixest)
# --- Question 3a: OLS regression with district fixed effects and robust SEs ---
reg <- feols(registered ~ social_norm | district,
data = merged,
vcov = "hetero")  # robust standard errors
# View results
summary(reg)
# Model 2: with control variables
reg2 <- feols(registered ~ social_norm + age + female + phone | district,
data = merged %>%
mutate(female = as.numeric(labelled::unlabelled(female)),
phone = as.numeric(phone == "Smartphone")),
vcov = "hetero")
summary(reg2)
# --- Professional regression table ---
etable(reg, reg2,
title = "Table 2. Effect of Social Norm Message on Registration",
headers = c("Model 1", "Model 2"),
coefstat = "se",
digits = 3,
fitstat = c("n", "r2", "ar2"),
notes = "Robust standard errors in parentheses. All models include district fixed effects.",
tex = FALSE)

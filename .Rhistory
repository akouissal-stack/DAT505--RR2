# --- Question 2a: Balance table ---
library(gtsummary)
balance_table <- merged %>%
select(registered, female, age, phone) %>%
tbl_summary(
by = registered,
label = list(
female ~ "Gender",
age    ~ "Age (years)",
phone  ~ "Phone type"
),
statistic = list(
all_continuous()  ~ "{mean} ({sd})",
all_categorical() ~ "{n} ({p}%)"
),
missing = "no"
) %>%
add_p() %>%                          # adds p-value column
add_overall() %>%                    # adds overall column
modify_header(
label      ~ "**Characteristic**",
stat_0     ~ "**Overall**",
stat_1     ~ "**Did not register**",
stat_2     ~ "**Registered**"
) %>%
modify_caption("**Table 1. Characteristics of Respondents by Registration Status**")
balance_table
